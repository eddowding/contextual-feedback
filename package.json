{
  "name": "contextual-feedback",
  "version": "0.2.0",
  "description": "Section-targeted feedback system for React applications. Let users click exactly what they're giving feedback about.",
  "keywords": [
    "feedback",
    "react",
    "nextjs",
    "user-feedback",
    "contextual",
    "section-targeting",
    "ux"
  ],
  "author": "Ed Dowding",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eddowding/contextual-feedback.git"
  },
  "homepage": "https://github.com/eddowding/contextual-feedback#readme",
  "bugs": {
    "url": "https://github.com/eddowding/contextual-feedback/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./adapters/postgres": {
      "import": {
        "types": "./dist/lib/adapters/postgres.d.mts",
        "default": "./dist/lib/adapters/postgres.mjs"
      },
      "require": {
        "types": "./dist/lib/adapters/postgres.d.ts",
        "default": "./dist/lib/adapters/postgres.js"
      }
    },
    "./adapters/supabase": {
      "import": {
        "types": "./dist/lib/adapters/supabase.d.mts",
        "default": "./dist/lib/adapters/supabase.mjs"
      },
      "require": {
        "types": "./dist/lib/adapters/supabase.d.ts",
        "default": "./dist/lib/adapters/supabase.js"
      }
    },
    "./adapters/memory": {
      "import": {
        "types": "./dist/lib/adapters/memory.d.mts",
        "default": "./dist/lib/adapters/memory.mjs"
      },
      "require": {
        "types": "./dist/lib/adapters/memory.d.ts",
        "default": "./dist/lib/adapters/memory.js"
      }
    },
    "./api": {
      "import": {
        "types": "./dist/api/handlers.d.mts",
        "default": "./dist/api/handlers.mjs"
      },
      "require": {
        "types": "./dist/api/handlers.d.ts",
        "default": "./dist/api/handlers.js"
      }
    },
    "./ai": {
      "import": {
        "types": "./dist/lib/ai.d.mts",
        "default": "./dist/lib/ai.mjs"
      },
      "require": {
        "types": "./dist/lib/ai.d.ts",
        "default": "./dist/lib/ai.js"
      }
    },
    "./setup": {
      "import": {
        "types": "./dist/setup/supabase.d.mts",
        "default": "./dist/setup/supabase.mjs"
      },
      "require": {
        "types": "./dist/setup/supabase.d.ts",
        "default": "./dist/setup/supabase.js"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "adapters/*": [
        "dist/lib/adapters/*.d.ts"
      ],
      "api": [
        "dist/api/handlers.d.ts"
      ],
      "ai": [
        "dist/lib/ai.d.ts"
      ],
      "setup": [
        "dist/setup/supabase.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsup",
    "prepare": "npm run build",
    "dev": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^9.39.4",
    "jsdom": "^29.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.4"
  }
}
